# ─────────────────────────────────────────────
# Smart Leads Dashboard — Backend .env.example
# Copy to .env and fill in values
# ─────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://admin:supersecretpassword@mongo:27017/smartleads?authSource=admin

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
