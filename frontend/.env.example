# ─────────────────────────────────────────────
# Smart Leads Dashboard — Frontend .env.example
# Copy to .env and fill in values (only needed if NOT using Docker Compose proxy)
# ─────────────────────────────────────────────

# In Docker/Vite setup, /api is proxied automatically. 
# But if you build for production outside Docker, set this to the backend URL.
VITE_API_URL=http://localhost:5000/api/v1
